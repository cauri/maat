# Maat public edge — terminates TLS (auto Let's Encrypt) for these hostnames:
#   • $MAAT_HOST        — PUBLIC. Serves ONLY the read API (/api/*). (api.maat.press)
#   • $MAAT_ADMIN_HOST  — the operator/admin console. Public *name* + real cert, but served
#                          ONLY to WireGuard source IPs (D31/D32). (admin.maat.press)
#   • www.maat.press    — PUBLIC. The marketing landing page + acquisition funnel (a separate
#                          loopback service); apex maat.press redirects here. No API here.
#
# Caddy runs on the HOST network (see docker-compose.prod.yml) so the `remote_ip` matcher sees
# the real client address — a WireGuard peer arrives as 10.8.0.x; the public internet does not.
# Because Caddy is host-networked it reaches every upstream over the host loopback (NOT compose
# service names): the reader on 127.0.0.1:8000, the marketing site on 127.0.0.1:8080.
# The admin cert is still issued over the public :80 (HTTP-01) — the A record is public, so no
# DNS-01 / OVH-API secret is needed (D32). The SSH tunnel stays as break-glass.

{$MAAT_HOST} {
	encode zstd gzip

	@api path /api /api/*
	handle @api {
		reverse_proxy 127.0.0.1:8000
	}

	# Everything else on the public host stays private — not reachable from the internet.
	handle {
		respond "Maat — not found" 404
	}
}

{$MAAT_ADMIN_HOST} {
	encode zstd gzip

	# Defence-in-depth layer 1 (network): serve the console only to the WireGuard subnet.
	# (Layer 2 is the Google-OIDC + allowlist gate, shared by both upstreams.) A real LE cert is
	# still presented to everyone; non-WG callers get a 403 instead of the login screen.
	@wg remote_ip {$MAAT_WG_SUBNET:10.8.0.0/24}
	handle @wg {
		# Console v2 cutover (D33/#292): the Next.js console (127.0.0.1:3100) serves the UI; the
		# FastAPI app (127.0.0.1:8000) keeps the OIDC login dance, the command/query API the
		# console + Sia call, the public read API, health, and static assets. Both verify the same
		# `maat_admin` cookie, so routing splits cleanly by path and the cookie rides along.
		@fastapi path /admin/* /admin /api/* /console/api/* /healthz /favicon.ico /static/*
		handle @fastapi {
			reverse_proxy 127.0.0.1:8000
		}
		# Everything else is the Next.js operator console.
		handle {
			reverse_proxy 127.0.0.1:3100
		}
	}
	handle {
		respond "Maat operator console — reachable only over the private network." 403
	}
}

# Marketing site (www.maat.press): the public landing page + acquisition funnel. Self-contained —
# the page only POSTs /track + /notify back to its own origin, so no API is exposed here. The admin
# /acquisition view lives on the private console, never on this host. Upstream is the marketing
# service on the host loopback (host-net Caddy → 127.0.0.1:8080, NOT a compose service name).
www.maat.press {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8080
}

# Send the apex to www so there's one canonical home.
maat.press {
	redir https://www.maat.press{uri} permanent
}
