# Copy to .env (gitignored) and fill in.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Claude routing (anthropic | bedrock-eu | vertex-eu) — legacy single-label placeholder per
# DECISIONS D7. Actual multi-endpoint routing is configured via MAAT_CLAUDE_ENDPOINTS below.
CLAUDE_ROUTE=anthropic

# Proactive LLM rate throttle (#300) — a token bucket caps the SUSTAINED request rate so the
# bounded worker pool saturates the tier without a 429 storm (retry/backoff absorbs the burst).
# 0 = off. Anthropic is off by default — set it to your account tier (cost is not the constraint;
# provision for throughput). Mistral defaults to ~50/min to respect its 60/min budget.
# These are the per-provider defaults; a multi-endpoint setup (below) sets rpm/tpm per endpoint.
# MAAT_CLAUDE_RPM=0       # requests/min (set to the Anthropic tier limit, or just below for headroom)
# MAAT_CLAUDE_TPM=0       # tokens/min
# MAAT_MISTRAL_RPM=50     # requests/min
# MAAT_MISTRAL_TPM=0      # tokens/min

# Multi-endpoint per-stage Claude routing (#300) — raise throughput past ONE tier's RPM/TPM by
# spreading calls over several Anthropic endpoints (typically several API keys, each its own tier),
# each with its own budget; aggregate RPM/TPM = the sum. UNSET → one endpoint = ANTHROPIC_API_KEY
# above (today's behaviour, no surprise). An endpoint object: {name, url?, auth? (x-api-key|bearer),
# key_env?, version?, headers?, rpm?, tpm?}; rpm/tpm default to MAAT_CLAUDE_{RPM,TPM}, url defaults
# to api.anthropic.com. "bearer" is for an Anthropic-compatible regional gateway/proxy (no AWS/GCP
# SDK — Maat runs on neither). Put each key in its own env var and reference it by key_env:
# ANTHROPIC_API_KEY_2=
# MAAT_CLAUDE_ENDPOINTS=[{"name":"acct-a","rpm":4000,"tpm":400000},{"name":"acct-b","key_env":"ANTHROPIC_API_KEY_2","rpm":4000,"tpm":400000}]
#
# Per-stage routes: stage → {endpoints:[names], policy:"round-robin"|"least-loaded"} (or a bare
# [names] list). Stages: extract, classify, extremity, geotag, ner, grounding, triage; "default"
# covers everything else (low-volume judge/console calls). UNSET → every stage spreads over ALL
# endpoints (round-robin). Below: spread the heavy stages (least-loaded sends a raised tier more
# traffic), pin judge to one endpoint.
# MAAT_CLAUDE_STAGE_ROUTES={"extract":{"endpoints":["acct-a","acct-b"],"policy":"least-loaded"},"classify":{"endpoints":["acct-a","acct-b"],"policy":"least-loaded"},"default":{"endpoints":["acct-a"]}}

# Local Postgres (docker-compose)
DATABASE_URL=postgresql://maat:maat@localhost:5432/maat
# Optional asyncpg pool sizing, owned by maat/db.py get_pool(). Defaults: min=1, max=10.
# Widen MAAT_DB_POOL_MAX on the serving box if the read path saturates the pool.
# MAAT_DB_POOL_MIN=1
# MAAT_DB_POOL_MAX=10
NATS_URL=nats://localhost:4222
